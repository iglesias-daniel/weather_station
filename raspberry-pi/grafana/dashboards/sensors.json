{
  "title": "Weather Station",
  "uid": "weather-station",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Temperature (°C)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": { "unit": "celsius" },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "query": "from(bucket: \"sensors\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"weather\" and r._field == \"temperature_c\")"
      }]
    },
    {
      "id": 2,
      "title": "Humidity (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": { "unit": "percent" },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "query": "from(bucket: \"sensors\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"weather\" and r._field == \"humidity_pct\")"
      }]
    },
    {
      "id": 3,
      "title": "Pressure (hPa)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": { "unit": "pressurehpa" },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "query": "from(bucket: \"sensors\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"weather\" and r._field == \"pressure_hpa\")"
      }]
    },
    {
      "id": 4,
      "title": "Wind Speed (m/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": { "unit": "velocityms" },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "query": "from(bucket: \"sensors\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"weather\" and r._field == \"wind_speed_ms\")"
      }]
    },
    {
      "id": 5,
      "title": "Rainfall (mm)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": { "unit": "lengthmm" },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "query": "from(bucket: \"sensors\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"weather\" and r._field == \"rain_mm\")"
      }]
    },
    {
      "id": 6,
      "title": "Battery Voltage (V)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": { "unit": "volt" },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "query": "from(bucket: \"sensors\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"weather\" and r._field == \"battery_v\")"
      }]
    }
  ]
}
